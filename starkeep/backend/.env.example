# Copy to .env and fill in values before running `python manage.py runserver`

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=starkeep
DB_USER=starkeep
DB_PASSWORD=starkeep
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set to "none" in dev to skip email verification during testing
ACCOUNT_EMAIL_VERIFICATION=none

# ─── Social OAuth (fill in from Google Cloud Console / Apple Developer) ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Archetype Quiz (Phase 2) ─────────────────────────────────────────────────
# QUIZ_REPO_WEBHOOK_SECRET — HMAC-SHA256 signing secret shared with the quiz repo
# QUIZ_INTEGRATION_TOKEN  — Bearer token the quiz repo uses to authenticate POSTs
# QUIZ_REPO_BASE_URL      — Hosted quiz URL (coordinate with quiz repo team per DEC-007)
QUIZ_REPO_WEBHOOK_SECRET=
QUIZ_INTEGRATION_TOKEN=
QUIZ_REPO_BASE_URL=

# ─── Email ────────────────────────────────────────────────────────────────────
# Dev default: console backend (prints to terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@starkeep.io
SENDGRID_API_KEY=

# ─── AI Microservice ─────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT=10
